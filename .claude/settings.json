{
  "permissions": {
    "allow": [
      "Bash(python3 src/manage.py test*)",
      "Bash(python3 -m pytest*)",
      "Bash(pytest*)",
      "Bash(npm test*)",
      "Bash(npm run build)",
      "Bash(flake8*)",
      "Bash(black --check*)",
      "Bash(ruff*)",
      "Bash(*manage.py migrate --dry-run*)",
      "Bash(*manage.py migrate --check*)",
      "Bash(*manage.py makemigrations --dry-run*)",
      "Bash(*manage.py makemigrations --check*)",
      "Read(*)"
    ],
    "deny": [
      "Bash(*rm -rf*)",
      "Bash(*DROP TABLE*)",
      "Bash(git*--force*)",
      "Bash(git push*)",
      "Bash(*git reset --hard*)",
      "Bash(*manage.py flush*)",
      "Bash(*manage.py dbshell*)",
      "Bash(*manage.py createsuperuser*)",
      "Read(*.env*)",
      "Edit(*.env*)",
      "Write(*.env*)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "allowedDomains": [
      "pypi.org",
      "registry.npmjs.org"
    ],
    "excludedCommands": [
      "curl",
      "wget"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "cd $CLAUDE_PROJECT_DIR/Backend/src && python3 manage.py test 2>&1"
        },
        {
          "type": "command",
          "command": "cd $CLAUDE_PROJECT_DIR/Frontend && PATH=\"$HOME/.nvm/versions/node/v12.22.12/bin:$PATH\" npm test -- --watchAll=false 2>&1"
        }]
      }
    ]
  }
}