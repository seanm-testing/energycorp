{
  "permissions": {
    "allow": [
      "Bash(python3 src/manage.py test*)",
      "Bash(npm test*)",
      "Bash(npm run build)",
      "Bash(ruff*)"
    ],
    "deny": [
      "Bash(*rm -rf*)",
      "Bash(*DROP TABLE*)",
      "Bash(git*--force*)",
      "Bash(git push*)",
      "Bash(*git reset --hard*)",
      "Bash(*manage.py flush*)",
      "Bash(*manage.py dbshell*)",
      "Bash(*manage.py createsuperuser*)",
      "Read(*.env*)",
      "Edit(*.env*)",
      "Write(*.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/track-changed-files.sh"
          },
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && ruff check --fix src/ 2>&1 | tail -20"
          },
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR/src && python3 manage.py test --failfast 2>&1 | tail -30"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/audit-permissions.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh"
          },
          {
            "type": "prompt",
            "model": "haiku",
            "prompt": "You are a code safety reviewer. The Bash command in tool_input.command may contain inline code (python3 -c, python3 -m, node -e, or similar). If the command contains inline code, analyze what the code actually does. DENY if the inline code deletes records, drops tables, truncates data, overwrites files, or performs any destructive write operation. ALLOW if the inline code only reads data, prints output, counts records, or performs analysis. Also ALLOW commands that do not contain inline code — those are handled by other hooks."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-hooks/changed-files.txt"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-prompt.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/review-on-stop.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/scan-on-stop.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -rf /tmp/claude-hooks/snapshots"
          }
        ]
      }
    ]
  },
  "additionalDirectories": [
    "../Frontend"
  ]
}
